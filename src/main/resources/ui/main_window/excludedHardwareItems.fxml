<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="root" spacing="10" style="-fx-padding: 15;"
      xmlns="http://javafx.com/javafx/20.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.faforever.moderatorclient.ui.main_window.ExcludedHardwareItemsController">

    <HBox spacing="10">
        <Button text="Open JSON File"   onAction="#handleOpenJsonFile"/>
        <Button text="Open Folder"      onAction="#handleOpenExcludedItemsFolder"/>
        <Button text="Backup JSON"      onAction="#handleOnCreateJsonBackup"/>
    </HBox>

    <Separator/>

    <SplitPane orientation="VERTICAL" VBox.vgrow="ALWAYS" dividerPositions="0.45">

        <!-- Input form -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
            <VBox spacing="12" style="-fx-padding: 5 5 5 0;">

                <TitledPane text="Annotation" expanded="true">
                    <GridPane hgap="10" vgap="8" style="-fx-padding: 10;">
                        <columnConstraints>
                            <ColumnConstraints minWidth="170" maxWidth="170"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="Comment:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <HBox spacing="8" alignment="CENTER_LEFT" GridPane.rowIndex="0" GridPane.columnIndex="1">
                            <TextField fx:id="commentField" promptText="Enter Comment" HBox.hgrow="ALWAYS"/>
                            <CheckBox fx:id="keepCommentFieldCheckBox" text="Keep"/>
                        </HBox>
                        <Label text="Reason:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <HBox spacing="8" alignment="CENTER_LEFT" GridPane.rowIndex="1" GridPane.columnIndex="1">
                            <TextField fx:id="reasonField" promptText="Enter Reason" HBox.hgrow="ALWAYS"/>
                            <CheckBox fx:id="keepReasonFieldCheckBox" text="Keep"/>
                        </HBox>
                    </GridPane>
                </TitledPane>

                <TitledPane text="Hardware Information" expanded="true">
                    <VBox spacing="10" style="-fx-padding: 10;">
                        <GridPane hgap="10" vgap="8">
                            <columnConstraints>
                                <ColumnConstraints minWidth="190" maxWidth="190"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>
                            <Label text="IP Address:"            GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="ipAddressField"    GridPane.rowIndex="0" GridPane.columnIndex="1" promptText="Enter IP Address"/>
                            <Label text="UUID:"                  GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="uuidField"         GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="Enter UUID"/>
                            <Label text="Device ID:"             GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="deviceIdField"     GridPane.rowIndex="2" GridPane.columnIndex="1" promptText="Enter Device ID"/>
                            <Label text="Manufacturer:"          GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <TextField fx:id="manufacturerField" GridPane.rowIndex="3" GridPane.columnIndex="1" promptText="Enter Manufacturer"/>
                            <Label text="CPU Name:"              GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <TextField fx:id="cpuNameField"      GridPane.rowIndex="4" GridPane.columnIndex="1" promptText="Enter CPU Name"/>
                            <Label text="Processor ID:"          GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                            <TextField fx:id="processorIdField"  GridPane.rowIndex="5" GridPane.columnIndex="1" promptText="Enter Processor ID"/>
                            <Label text="Serial Number:"         GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                            <TextField fx:id="serialNumberField" GridPane.rowIndex="6" GridPane.columnIndex="1" promptText="Enter Serial Number"/>
                            <Label text="Volume Serial Number:"  GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                            <TextField fx:id="volumeSerialNumberField" GridPane.rowIndex="7" GridPane.columnIndex="1" promptText="Enter Volume Serial Number"/>
                            <Label text="Hash:"                  GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                            <TextField fx:id="hashField"         GridPane.rowIndex="8" GridPane.columnIndex="1" promptText="Enter Hash"/>
                            <Label text="Memory Serial Number:"  GridPane.rowIndex="9" GridPane.columnIndex="0"/>
                            <TextField fx:id="memorySerialNumberField" GridPane.rowIndex="9" GridPane.columnIndex="1" promptText="Enter Memory Serial Number"/>
                        </GridPane>
                        <Button fx:id="addItemButton" text="Add Excluded Item" onAction="#handleAddItem"/>
                    </VBox>
                </TitledPane>

            </VBox>
        </ScrollPane>

        <!-- Existing excluded items -->
        <VBox spacing="5" style="-fx-padding: 5 0 0 0;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Excluded Items" style="-fx-font-weight: bold;"/>
                <Label fx:id="statsExcludedItemsLabel" style="-fx-text-fill: gray;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="tableSearchField" promptText="Search…" prefWidth="200"/>
                <Button fx:id="removeItemButton" text="Remove Selected" onAction="#handleRemoveItem" disable="true"/>
            </HBox>
            <TableView fx:id="excludedItemsTable" VBox.vgrow="ALWAYS"/>
        </VBox>

    </SplitPane>

</VBox>
