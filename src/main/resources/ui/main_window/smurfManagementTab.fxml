<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox fx:id="root" spacing="5" style="-fx-padding: 10px;" xmlns="http://javafx.com/javafx/20.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.faforever.moderatorclient.ui.main_window.SmurfManagementController">

    <HBox spacing="10">
        <Button text="Open JSON" onAction="#openJsonFile"/>
        <Button text="Create Backup" onAction="#createBackupJson"/>
        <Button text="Run Smurf Management" onAction="#runSmurfManagementButton"/>
    </HBox>

    <!-- SmurfManagement table will be added in the initialize method here -->
</VBox>
