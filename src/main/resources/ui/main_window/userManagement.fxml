<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TitledPane?>

<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.Tooltip?>
<SplitPane xmlns="http://javafx.com/javafx/8.0.171"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:id="root"
           fx:controller="com.faforever.moderatorclient.ui.main_window.UserManagementController"
           dividerPositions="0.3"
           orientation="VERTICAL"
           prefHeight="600.0">

    <SplitPane>
        <ScrollPane maxHeight="Infinity" maxWidth="-Infinity" HBox.hgrow="ALWAYS" hbarPolicy="NEVER">
            <VBox minWidth="220.0" maxWidth="440.0" spacing="7">

                <TitledPane text="User Search">
                    <VBox spacing="5">
                        <ComboBox fx:id="searchUserProperties" promptText="Search by" visibleRowCount="42"/>
                        <TextField fx:id="userSearchTextField" onAction="#onUserSearch" promptText="Enter search text"/>
                        <HBox spacing="5" alignment="CENTER">
                            <Button text="Search" onAction="#onUserSearch" mnemonicParsing="false" alignment="CENTER_LEFT"/>
                            <Button text="Previous Search" onAction="#onUserPreviousSearch" mnemonicParsing="false"
                                    alignment="CENTER_LEFT"/>
                        </HBox>
                    </VBox>
                </TitledPane>

                <TitledPane text="History &amp; Notes" fx:id="searchHistoryTitledPane">
                    <VBox spacing="10">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="searchHistoryLabel" text="Search History:" style="-fx-font-weight: bold;" />
                            <Button fx:id="minimizeSearchHistoryButton" text="Minimize" onAction="#handleMinimizeSearchHistory"/>
                        </HBox>
                        <TextArea fx:id="searchHistoryTextArea" promptText="No history available" wrapText="true" prefHeight="100" prefWidth="400"/>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="userNotesLabel" text="User Notes:" style="-fx-font-weight: bold;" />
                            <Button fx:id="minimizeUserNotesButton" text="Minimize" onAction="#handleMinimizeUserNotes"/>
                        </HBox>
                        <TextArea fx:id="userNotesTextArea" promptText="Add your notes here" wrapText="true" prefHeight="100" prefWidth="400"/>
                    </VBox>
                </TitledPane>

                <TitledPane text="Smurf Village Lookup" fx:id="smurfVillageLookupTitledPane">
                    <VBox spacing="10">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="ID/Name/Attr:" style="-fx-font-size: 14px;"/>
                            <TextField fx:id="smurfVillageLookupTextField" promptText="Enter ID/Name/Attr" onAction="#onLookupSmurfVillage"/>
                            <Button text="Lookup" onAction="#onLookupSmurfVillage" mnemonicParsing="false"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="statusLabelSmurfVillageLookup" text="Idle" style="-fx-background-color: blue; -fx-text-fill: white;"/>
                            <TextField fx:id="statusTextFieldProcessingPlayerID" text="Status" editable="false"/>
                        </HBox>
                        <TextField fx:id="statusTextFieldProcessingItem" text="Detailed Status Information" editable="false"/>
                        <!-- Smurf Village Lookup Settings -->

                        <TitledPane text="Smurf Village Lookup Settings" fx:id="smurfVillageLookupSettingsTitledPane">
                            <VBox spacing="5">
                                <Label text="Maximum Matches Before Prompt (Safeguard):"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <TextField fx:id="maxMatchesBeforePromptSmurfVillageLookupTextField"
                                               text="10"
                                               prefColumnCount="4"
                                               minWidth="50"/>
                                    <CheckBox fx:id="promptUserOnThresholdExceededSmurfVillageLookupCheckBox"
                                              text="Prompt User When Exceeded"
                                              selected="true"/>
                                </HBox>

                                <!-- Basic Identification -->
                                <Label text="Basic Identifications"/>
                                <CheckBox fx:id="includeUIDHashCheckBox" text="Include Hash"/>
                                <CheckBox fx:id="includeUUIDCheckBox" text="Include UUID"/>
                                <CheckBox fx:id="includeIPCheckBox" text="Include IP"/>

                                <!-- Advanced Identification -->
                                <Label text="Advanced Identification"/>
                                <HBox spacing="5">
                                    <Button fx:id="toggleAllAdvancedIdentificationButton" text="Toggle All"/>
                                </HBox>
                                <CheckBox fx:id="includeMemorySerialNumberCheckBox"
                                          text="Include Memory Serial Number"/>
                                <CheckBox fx:id="includeVolumeSerialNumberCheckBox"
                                          text="Include Volume Serial Number"/>
                                <CheckBox fx:id="includeSerialNumberCheckBox" text="Include Serial Number"/>
                                <CheckBox fx:id="includeProcessorIdCheckBox" text="Include Processor Id"/>
                                <CheckBox fx:id="includeProcessorNameCheckBox" text="Include Processor Name"/>
                                <CheckBox fx:id="includeManufacturerCheckBox" text="Include Manufacturer"/>

                                <!-- Expert Settings -->
                                <Label text="Expert Settings"/>
                                <CheckBox fx:id="catchFirstLayerSmurfsOnlyCheckBox"
                                          text="Limit to First Layer Accounts (See Tooltip)">
                                    <tooltip>
                                        <Tooltip wrapText="true" prefWidth="300">
                                            <text>I am getting replaced in the initializing part.</text>
                                        </Tooltip>
                                    </tooltip>
                                </CheckBox>

                            </VBox>
                        </TitledPane>

                    </VBox>
                </TitledPane>

                <TitledPane text="Ban Checker &amp; Smurf Management" fx:id="banCheckerSmurfManagementTitledPane">
                    <VBox spacing="10">
                        <Label text="Smurf Village Lookup Settings will be applied."/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="checkTemporaryBansButton" text="Check Temporary Bans" onAction="#handleCheckTemporaryBans"/>
                            <Label fx:id="temporaryBanProgressLabel" style="-fx-font-size: 12px; -fx-text-fill: gray;"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="checkSmurfManagementAccountsButton" text="Run Smurf Management" onAction="#handleCheckSmurfManagementAccounts"/>
                            <Label fx:id="smurfManagementProgressLabel" style="-fx-font-size: 12px; -fx-text-fill: gray;"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                        </HBox>
                    </VBox>
                </TitledPane>

                <TitledPane text="Latest Registrations" fx:id="latestRegistrationsTitledPane">
                    <VBox spacing="10">
                        <Label text="Smurf Village Lookup Settings will be applied."/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="checkRecentAccountsForSmurfsButton" text="Check For Smurf Accounts"
                                    onAction="#checkRecentAccountsForSmurfs" mnemonicParsing="false"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Text fx:id="statusTextRecentAccountsForSmurfs" text="Status: 0/?"/>
                            <Button fx:id="checkRecentAccountsForSmurfsPauseButton" text="Pause"
                                    onAction="#checkRecentAccountsForSmurfsPause" mnemonicParsing="false"/>
                            <Button fx:id="checkRecentAccountsForSmurfsStopButton" text="Stop"
                                    onAction="#checkRecentAccountsForSmurfsStop" mnemonicParsing="false"/>
                        </HBox>
                        <Text text="Number of days to check recent accounts" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="daysToCheckRecentAccountsTextField"
                                   promptText="Number of days"/>
                        <Separator/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="ProgressLabelRecentAccountsSmurfCheck" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label HBox.hgrow="ALWAYS" text="Pause/stop = on new account"/>
                        </HBox>
                    </VBox>
                </TitledPane>
            </VBox>
        </ScrollPane>

        <TableView fx:id="userSearchTableView" maxWidth="Infinity" minWidth="550.0" prefHeight="200.0" HBox.hgrow="ALWAYS"/>
    </SplitPane>

    <TabPane minHeight="200.0" tabClosingPolicy="UNAVAILABLE">
        <Tab fx:id="notesTab" text="Notes">
            <VBox maxWidth="Infinity" maxHeight="Infinity">
                <TableView fx:id="userNoteTableView" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <VBox.margin>
                        <Insets bottom="10.0"/>
                    </VBox.margin>
                </TableView>
                <HBox alignment="CENTER">
                    <Button fx:id="addNoteButton" text="Add note" onAction="#addNote" mnemonicParsing="false"/>
                    <Button fx:id="editNoteButton" text="Edit selected note" onAction="#editNote" mnemonicParsing="false">
                        <HBox.margin>
                            <Insets left="10.0"/>
                        </HBox.margin>
                    </Button>
                    <Button fx:id="removeNoteButton" text="Remove note (No Permission)" onAction="#removeNote" mnemonicParsing="false" disable="true">
                        <HBox.margin>
                            <Insets left="10.0"/>
                        </HBox.margin>
                    </Button>
                </HBox>
            </VBox>
        </Tab>
        <Tab fx:id="bansTab" text="Bans">
            <VBox>
                <TableView fx:id="userBansTableView" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <VBox.margin>
                        <Insets bottom="10.0"/>
                    </VBox.margin>
                </TableView>
                <HBox alignment="CENTER">
                    <Button fx:id="newBanButton" text="Apply new ban" onAction="#onNewBan" mnemonicParsing="false" disable="true">
                        <HBox.margin>
                            <Insets/>
                        </HBox.margin>
                    </Button>
                    <Button fx:id="editBanButton" text="Edit selected ban" onAction="#onEditBan" mnemonicParsing="false" disable="true">
                        <HBox.margin>
                            <Insets left="10.0"/>
                        </HBox.margin>
                    </Button>
                </HBox>
            </VBox>
        </Tab>
        <Tab fx:id="teamkillsTab" text="Teamkills">
            <TableView fx:id="userTeamkillsTableView" prefHeight="200.0" prefWidth="200.0"/>
        </Tab>
        <Tab fx:id="nameHistoryTab" text="Name History">
            <TableView fx:id="userNameHistoryTableView" maxWidth="Infinity" maxHeight="Infinity" prefHeight="200.0"/>
        </Tab>
        <Tab fx:id="lastGamesTab" text="Last Games">
            <VBox spacing="5">
                <HBox spacing="10">
                    <VBox.margin>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                    </VBox.margin>
                    <Label maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                           text="Show featured Mods:"/>
                    <ChoiceBox fx:id="featuredModFilterChoiceBox" minWidth="150.0"/>
                    <Label text="Enter manually or select two accounts from userTable"/>
                    <Label text="Check for Shared Games between"/>
                    <TextField fx:id="playerIDField1SharedGamesTextfield" minWidth="100.0" promptText="PlayerID"/>
                    <Label text="and" alignment="CENTER"/>
                    <TextField fx:id="playerIDField2SharedGamesTextfield" minWidth="100.0" promptText="PlayerID"/>
                    <Button fx:id="checkSharedGamesButton" text="Check for Shared Games (Last 1,000)"
                            onAction="#onCheckSharedGames" mnemonicParsing="false"/>
                    <Label fx:id="progressLabelSharedGames" visible="false" minWidth="150"/>
                </HBox>

                <TableView fx:id="userLastGamesTable" maxHeight="1.7976931348623157E308"
                           maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS"/>
            </VBox>
        </Tab>
        <Tab fx:id="avatarsTab" text="Avatars">
            <VBox>
                <TableView fx:id="userAvatarsTableView" maxWidth="Infinity" maxHeight="Infinity" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="10.0">
                    <Button fx:id="giveAvatarButton" text="Give selected avatar from main avatar tab" onAction="#onGiveAvatar" mnemonicParsing="false"/>
                    <Separator orientation="VERTICAL"/>
                    <TextField fx:id="expiresAtTextfield" promptText="2018-12-31T23:59:59Z"/>
                    <Button fx:id="setExpiresAtButton" text="Set expires at" onAction="#onSetExpiresAt" mnemonicParsing="false"/>
                    <Separator orientation="VERTICAL"/>
                    <Button fx:id="takeAvatarButton" text="Take avatar" onAction="#onTakeAvatar" mnemonicParsing="false"/>
                </HBox>
            </VBox>
        </Tab>
        <Tab fx:id="userGroupsTab" text="User Groups">
            <VBox>
                <HBox VBox.vgrow="ALWAYS">
                    <TableView fx:id="userGroupsTableView" maxWidth="Infinity" maxHeight="Infinity" prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS"/>
                    <TableView fx:id="permissionsTableView" maxWidth="Infinity" maxHeight="Infinity" prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS"/>
                </HBox>
                <HBox VBox.vgrow="NEVER" maxHeight="50.0" spacing="10.0" alignment="CENTER">
                    <Button text="Add User To Group" onAction="#openGroupDialog"/>
                    <Button fx:id="removeGroupButton" text="Remove Group" onAction="#onRemoveGroup"/>
                </HBox>
            </VBox>
        </Tab>

        <Tab fx:id="smurfOutputTab" text="Smurf Village">
            <VBox>
                <TextArea fx:id="smurfOutputTextArea" VBox.vgrow="ALWAYS"/>
            </VBox>
        </Tab>
    </TabPane>
</SplitPane>