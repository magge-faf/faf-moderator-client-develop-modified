<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml/1" fx:id="root" maxHeight="1.7976931348623157E308"
      maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/8.0.141"
      fx:controller="com.faforever.moderatorclient.ui.BansController">
    <VBox minWidth="200.0">
        <HBox.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
        </HBox.margin>
        <fx:define>
            <ToggleGroup fx:id="filterGroup"/>
        </fx:define>
        <RadioButton fx:id="playerRadioButton" selected="true" mnemonicParsing="false" text="Player Name"
                     toggleGroup="$filterGroup">
            <VBox.margin>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
            </VBox.margin>
        </RadioButton>
        <RadioButton fx:id="banIdRadioButton" mnemonicParsing="false" text="Ban ID" toggleGroup="$filterGroup">
            <VBox.margin>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
            </VBox.margin>
        </RadioButton>
        <TextField fx:id="filter" promptText="Filter value">
            <VBox.margin>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
            </VBox.margin>
        </TextField>
        <CheckBox text="Only active bans" selected="true" fx:id="onlyActiveCheckBox">
            <VBox.margin>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
            </VBox.margin>
        </CheckBox>
        <Button mnemonicParsing="false" onAction="#onSearch" text="Search">
            <VBox.margin>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
            </VBox.margin>
        </Button>
        <Separator prefWidth="200.0"/>
        <Button mnemonicParsing="false" onAction="#onRefreshLatestBans" text="Load newest">
            <VBox.margin>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
            </VBox.margin>
        </Button>
        <Button fx:id="editBanButton" mnemonicParsing="false" onAction="#editBan" text="Edit Ban">
            <VBox.margin>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
            </VBox.margin>
        </Button>
        <Button layoutX="15.0" layoutY="50.0" mnemonicParsing="false" onAction="#addBan" text="Add Ban">
            <VBox.margin>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
            </VBox.margin>
        </Button>
        <Separator/>
        <Label text="WIP - but should work"/>
        <Label text="User Ban Synchronization"/>
        <Label text="Do not sync both at the same time."/>
        <Label text="Doing so will cause malformed JSON data."/>
        <Label text="You can resume syncs after closing Mordor (Supposedly)."/>
        <Label text="Sync Perm will take a very long time."/>
        <Label text="(Better backup the file between sessions)"/>

        <Separator/>
        <HBox alignment="CENTER_LEFT" spacing="5.0">
            <Button layoutX="15.0" layoutY="50.0" mnemonicParsing="false" onAction="#syncTempBannedUsersJson" text="Sync Temporary Bans">
                <VBox.margin>
                    <Insets bottom="5.0" left="5.0" right="5.0" top="10.0"/>
                </VBox.margin>
            </Button>
            <Label fx:id="tempBanCountLabel"/>
        </HBox>
        <VBox fx:id="tempSyncProgressContainer" alignment="CENTER" spacing="5">
            <ProgressIndicator fx:id="tempSyncProgressIndicator" visible="false" managed="false"/>
            <Label fx:id="tempSyncProgressLabel" visible="false" managed="false"/>
            <VBox.margin>
                <Insets bottom="5.0" left="5.0" right="5.0" top="2.0"/>
            </VBox.margin>
        </VBox>
        <HBox alignment="CENTER_LEFT" spacing="5">

            <Button layoutX="15.0" layoutY="50.0" mnemonicParsing="false" onAction="#syncPermBannedUsersJson"
                    text="Sync Permanent Bans">
                <VBox.margin>
                    <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                </VBox.margin>
            </Button>
            <Label fx:id="permBanCountLabel"/>
        </HBox>
        <VBox fx:id="permSyncProgressContainer" alignment="CENTER" spacing="5">
            <ProgressIndicator fx:id="permSyncProgressIndicator" visible="false" managed="false"/>
            <Label fx:id="permSyncProgressLabel" visible="false" managed="false"/>
            <VBox.margin>
                <Insets bottom="5.0" left="5.0" right="5.0" top="2.0"/>
            </VBox.margin>
        </VBox>
    </VBox>
    <TableView fx:id="banTableView" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
               HBox.hgrow="ALWAYS"/>
</HBox>